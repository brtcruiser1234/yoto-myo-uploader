{
  "name": "yoto-myo-uploader",
  "version": "1.0.0",
  "description": "Upload local audiobook folders to Yoto MYO cards, with a built-in web browser for your library",
  "type": "module",
  "bin": {
    "yoto-convert": "./bin/yoto-convert.js",
    "yoto-upload": "./bin/yoto-upload.js",
    "yoto-serve": "./bin/yoto-serve.js",
    "yoto-patch-covers": "./bin/yoto-patch-covers.js"
  },
  "scripts": {
    "convert": "node bin/yoto-convert.js",
    "upload": "node bin/yoto-upload.js",
    "serve": "node bin/yoto-serve.js",
    "patch-covers": "node bin/yoto-patch-covers.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "express": "^4.21.2",
    "yoto-nodejs-client": "^0.0.11"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["yoto", "myo", "audiobook", "upload"],
  "license": "MIT"
}
